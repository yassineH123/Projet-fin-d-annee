# ─── Serveur ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Base de données ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/atlasway

# ─── JWT ────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_with_a_strong_random_secret

# ─── Email (SMTP) ────────────────────────────────────────────
# Laisser vide pour désactiver (mode console log en dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_app_password_gmail
SMTP_FROM=AtlasWay <votre_email@gmail.com>

# ─── Twilio SMS ──────────────────────────────────────────────
# Laisser vide pour afficher le code en console (mode dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ─── Stripe ──────────────────────────────────────────────────
# Laisser vide pour désactiver les paiements réels
# Clés test disponibles sur dashboard.stripe.com → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Web Push (VAPID) ────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:contact@atlasway.ma

# ─── Ollama (AtlasBot + Prédictions IA) ─────────────────────
# URL du serveur Ollama local (défaut: http://localhost:11434)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_FALLBACK_MODEL=mistral
